{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "declaration": true,
    "sourceMap": true,
    "removeComments": true,

    "incremental": true,

    "strict": false,
    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts"
  ]
}