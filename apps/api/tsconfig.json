{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",

    "target": "ES2021",
    "lib": ["ES2021"],

    "declaration": true,
    "sourceMap": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "useDefineForClassFields": false,

    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "incremental": true,

    "strict": false,

    "baseUrl": "./",

    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma/seed.ts"]
}